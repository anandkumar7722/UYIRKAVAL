# ─────────────────────────────────────────────────────────────────
# Android / Gradle
# ─────────────────────────────────────────────────────────────────

# Built application files
*.apk
*.aar
*.ap_
*.aab

# Files for the ART/Dalvik VM
*.dex

# Java class files
*.class

# Generated files
bin/
gen/
out/

# Gradle files
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar

# Local configuration file (SDK path, etc.)
local.properties

# Proguard folder generated by Eclipse
proguard/

# Log files
*.log

# Android Studio Navigation editor temp files
.navigation/

# Android Studio captures folder
captures/

# External native build folder
.externalNativeBuild/
.cxx/

# Kotlin
.kotlin/

# ─────────────────────────────────────────────────────────────────
# IntelliJ / Android Studio IDE
# ─────────────────────────────────────────────────────────────────

.idea/
*.iml
*.iws
*.ipr

# ─────────────────────────────────────────────────────────────────
# Keystore files (uncomment to ignore)
# ─────────────────────────────────────────────────────────────────
# *.jks
# *.keystore

# ─────────────────────────────────────────────────────────────────
# Google Services (uncomment if private)
# ─────────────────────────────────────────────────────────────────
# google-services.json

# ─────────────────────────────────────────────────────────────────
# Python (backend)
# ─────────────────────────────────────────────────────────────────

__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
*.egg

# Virtual environments
venv/
.venv/
env/

# Environment variables (NEVER commit)
.env
.env.*

# ─────────────────────────────────────────────────────────────────
# IDE / Editor
# ─────────────────────────────────────────────────────────────────

.vscode/
*.swp
*.swo
*~

# ─────────────────────────────────────────────────────────────────
# OS-specific
# ─────────────────────────────────────────────────────────────────

.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
